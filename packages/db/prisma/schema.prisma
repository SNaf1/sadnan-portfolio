datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Project {
  id           String   @id @default(uuid())
  title        String
  description  String
  content      String   @db.Text
  imageUrl     String?
  githubLink   String?
  demoLink     String?
  tags         String[]
  status       String   @default("DRAFT")
  priority     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Skill {
  id          String   @id @default(uuid())
  name        String
  category    String
  proficiency Int
  iconName    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Visitor {
  id                 String              @id @default(uuid())
  firstTouchSource   String
  firstTouchMedium   String?
  firstTouchCampaign String?
  firstTouchUrl      String
  createdAt          DateTime            @default(now())
  sessions           Session[]
  submissions        ContactSubmission[]
}

model Session {
  id              String              @id @default(uuid())
  visitorId       String
  visitor         Visitor             @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  lastTouchSource String
  lastTouchMedium String?
  referrer        String?
  landingPage     String
  gclid           String?
  fbclid          String?
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  utmContent      String?
  createdAt       DateTime            @default(now())
  submissions     ContactSubmission[]
  events          AnalyticsEvent[]
}

model ContactSubmission {
  id        String   @id @default(uuid())
  visitorId String
  visitor   Visitor  @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  eventType String   // e.g. VIEW_PROJECT, DOWNLOAD_CV, TOGGLE_THEME, SOCIAL_CLICK
  details   String?  // e.g. echosort, dark, github
  createdAt DateTime @default(now())
}
